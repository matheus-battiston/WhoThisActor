# Estágio de construção
FROM maven:3.8.5-openjdk-17-slim AS build
ARG CONNECTIONSTRING
ARG TMDBAPIKEY
ARG SENHAKEYSTORE
ARG DBPASSWORD
ARG CLASSIFYADDRESS

ENV CLASSIFYADDRESS=$CLASSIFYADDRESS
ENV CONNECTIONSTRING=$CONNECTIONSTRING
ENV TMDBAPIKEY=$TMDBAPIKEY
ENV SENHAKEYSTORE=$SENHAKEYSTORE
ENV DBPASSWORD=$DBPASSWORD
WORKDIR /app
COPY src /app/src
COPY pom.xml /app
COPY keystore.jks /app/keystore.jks
RUN mvn -f /app/pom.xml clean package -DskipTests

# Estágio de execução
FROM openjdk:17-slim
ARG CONNECTIONSTRING
ARG SENHAKEYSTORE
ARG TMDBAPIKEY
ARG DBPASSWORD
ARG CLASSIFYADDRESS

ENV CLASSIFYADDRESS=$CLASSIFYADDRESS
ENV CONNECTIONSTRING=$CONNECTIONSTRING
ENV TMDBAPIKEY=$TMDBAPIKEY
ENV SENHAKEYSTORE=$SENHAKEYSTORE
ENV DBPASSWORD=$DBPASSWORD
WORKDIR /app
COPY --from=build /app/target/MovieParticipations-0.0.1-SNAPSHOT.jar /app/MovieParticipations-0.0.1.jar
COPY --from=build /app/keystore.jks /app/keystore.jks
EXPOSE 8080 8443
ENTRYPOINT ["java", "-jar", "/app/MovieParticipations-0.0.1.jar"]