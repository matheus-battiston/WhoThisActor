
#POSTGRES
POSTGRES_HOST=
DB_PASSWORD=
DB_USER=
DB_URL=jdbc:postgresql://host.docker.internal:5432/WhoThisActor

#Serviço de classificaçao
CLASSIFYADDRESS=http://host.docker.internal:8000/classify
CLASSIFY_CACHE_RELOAD_ADDRESS=http://host.docker.internal:8000/cache/atores-por-producao/recarregar


#API key para desenvolvedores no tmdb
TMDBAPIKEY=

#Autenticaçao
# Autenticação é gerenciada pelo Auth Service (repositório separado)
# Ver: https://github.com/matheus-battiston/AuthMatheus
AUTH_SERVICE_URL=
#Valor da public key gerada referente ao projeto de autenticaçao
JWT_PUBLIC_KEY=

#Front
FRONT_URL=http://localhost:3000/